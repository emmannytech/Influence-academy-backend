# Database (Supabase PostgreSQL — connection pooling via PgBouncer)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (used for Prisma migrations only)
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-eu-west-1.pooler.supabase.com:5432/postgres"

# Supabase
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Email (Resend)
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM_ADDRESS="Influence Academy <noreply@yourdomain.com>"

# App
NODE_ENV="development"
PORT=3001
CORS_ORIGIN="http://localhost:3000"
APP_BASE_URL="http://localhost:3001"
