generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  creator
  client
  admin
}

enum CreatorStatus {
  draft
  submitted
  under_review
  approved
  rejected
}

enum ClientType {
  brand
  agency
}

enum NotificationType {
  info
  success
  warning
  error
}

enum InvitationStatus {
  pending
  accepted
  declined
}

enum CampaignStatus {
  draft
  submitted
  active
  completed
  rejected
}

enum SetupCategory {
  country
  city
  niche
  platform
  industry
}

enum KpiType {
  posts
  reach
  impressions
  views
  engagement
  clicks
  conversions
}

enum SubmissionStatus {
  pending
  approved
  rejected
}

model SetupItem {
  id        String        @id @default(uuid())
  category  SetupCategory
  label     String
  value     String
  isActive  Boolean       @default(true) @map("is_active")
  sortOrder Int           @default(0) @map("sort_order")
  parentId  String?       @map("parent_id")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  parent   SetupItem?  @relation("SetupItemParent", fields: [parentId], references: [id], onDelete: Cascade)
  children SetupItem[] @relation("SetupItemParent")

  @@unique([category, value, parentId])
  @@index([category, isActive, sortOrder])
  @@index([parentId])
  @@map("setup_items")
}

model User {
  id         String   @id @default(uuid())
  supabaseId String   @unique @map("supabase_id")
  email      String   @unique
  role       UserRole
  isVerified Boolean  @default(false) @map("is_verified")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  creator       Creator?
  client        Client?
  notifications Notification[]

  @@map("users")
}

model Creator {
  id              String        @id @default(uuid())
  userId          String        @unique @map("user_id")
  fullName        String?       @map("full_name")
  dateOfBirth     DateTime?     @map("date_of_birth")
  country         String?
  city            String?
  location        String?
  contactNumber   String?       @map("contact_number")
  email           String?
  bio             String?
  niches          String[]      @default([])
  socialHandles   Json?         @map("social_handles")
  profilePicture  String?       @map("profile_picture")
  status          CreatorStatus @default(draft)
  rejectionReason String?       @map("rejection_reason")
  adminNotes      String?       @map("admin_notes")
  submittedAt     DateTime?     @map("submitted_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shortlists      ShortlistCreator[]
  invitations     Invitation[]
  postSubmissions CampaignPostSubmission[]
  metricOverrides CampaignMetricOverride[]

  @@map("creators")
}

model Client {
  id                String      @id @default(uuid())
  userId            String      @unique @map("user_id")
  companyName       String?     @map("company_name")
  companyType       ClientType? @map("company_type")
  companyWebsite    String?     @map("company_website")
  industry          String?
  contactPersonName String?     @map("contact_person_name")
  contactEmail      String?     @map("contact_email")
  contactPhone      String?     @map("contact_phone")
  country           String?
  officeAddress     String?     @map("office_address")
  companyLogo       String?     @map("company_logo")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns Campaign[]

  @@map("clients")
}

model Campaign {
  id               String         @id @default(uuid())
  clientId         String         @map("client_id")
  title            String
  description      String?
  platforms        String[]       @default([])
  requirements     Json?
  numberOfCreators Int?           @map("number_of_creators")
  timeline         Json?
  budget           Float?
  status           CampaignStatus @default(draft)
  coverImage       String?        @map("cover_image")
  adminNotes       String?        @map("admin_notes")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  client              Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  statusLogs          CampaignStatusLog[]
  shortlistedCreators ShortlistCreator[]
  shareLinks          ShareLink[]
  invitations         Invitation[]
  assets              CampaignAsset[]
  kpis                CampaignKpi[]
  postSubmissions     CampaignPostSubmission[]
  metricOverrides     CampaignMetricOverride[]

  @@map("campaigns")
}

model CampaignStatusLog {
  id          String          @id @default(uuid())
  campaignId  String          @map("campaign_id")
  fromStatus  CampaignStatus? @map("from_status")
  toStatus    CampaignStatus  @map("to_status")
  note        String?
  changedById String?         @map("changed_by_id")
  createdAt   DateTime        @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_status_logs")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType @default(info)
  title     String
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model ShortlistCreator {
  id         String   @id @default(uuid())
  campaignId String   @map("campaign_id")
  creatorId  String   @map("creator_id")
  addedAt    DateTime @default(now()) @map("added_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator  Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([campaignId, creatorId])
  @@map("shortlist_creators")
}

model ShareLink {
  id         String   @id @default(uuid())
  campaignId String   @map("campaign_id")
  token      String   @unique @default(uuid())
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  decisions  Json?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("share_links")
}

model Invitation {
  id          String           @id @default(uuid())
  campaignId  String           @map("campaign_id")
  creatorId   String           @map("creator_id")
  status      InvitationStatus @default(pending)
  sentAt      DateTime         @default(now()) @map("sent_at")
  respondedAt DateTime?        @map("responded_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator  Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([campaignId, creatorId])
  @@map("invitations")
}

model CampaignAsset {
  id          String   @id @default(uuid())
  campaignId  String   @map("campaign_id")
  fileName    String   @map("file_name")
  storagePath String   @map("storage_path")
  mimeType    String   @map("mime_type")
  sizeBytes   Int      @map("size_bytes")
  uploadedAt  DateTime @default(now()) @map("uploaded_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("campaign_assets")
}

model CampaignKpi {
  id          String   @id @default(uuid())
  campaignId  String   @map("campaign_id")
  type        KpiType
  targetValue Int      @map("target_value")
  perCreator  Boolean  @default(true) @map("per_creator")
  createdAt   DateTime @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, type])
  @@map("campaign_kpis")
}

model CampaignPostSubmission {
  id         String    @id @default(uuid())
  campaignId String    @map("campaign_id")
  creatorId  String    @map("creator_id")
  platform   String
  postUrl    String    @map("post_url")
  postedAt   DateTime? @map("posted_at")

  reach       Int?
  impressions Int?
  views       Int?
  engagement  Int?
  clicks      Int?
  conversions Int?

  status      SubmissionStatus @default(pending)
  reviewNote  String?          @map("review_note")
  submittedAt DateTime         @default(now()) @map("submitted_at")
  reviewedAt  DateTime?        @map("reviewed_at")

  campaign Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator  Creator             @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  proofs   CampaignPostProof[]

  @@index([campaignId, creatorId])
  @@index([campaignId, status])
  @@map("campaign_post_submissions")
}

model CampaignPostProof {
  id           String   @id @default(uuid())
  submissionId String   @map("submission_id")
  fileName     String   @map("file_name")
  storagePath  String   @map("storage_path")
  mimeType     String   @map("mime_type")
  sizeBytes    Int      @map("size_bytes")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  submission CampaignPostSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("campaign_post_proofs")
}

model CampaignMetricOverride {
  id            String           @id @default(uuid())
  campaignId    String           @map("campaign_id")
  creatorId     String           @map("creator_id")
  type          KpiType
  reportedValue Int              @map("reported_value")
  note          String?
  status        SubmissionStatus @default(pending)
  reviewNote    String?          @map("review_note")
  createdAt     DateTime         @default(now()) @map("created_at")
  reviewedAt    DateTime?        @map("reviewed_at")

  campaign Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator  Creator               @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  proofs   CampaignMetricProof[]

  @@unique([campaignId, creatorId, type])
  @@map("campaign_metric_overrides")
}

model CampaignMetricProof {
  id          String   @id @default(uuid())
  overrideId  String   @map("override_id")
  fileName    String   @map("file_name")
  storagePath String   @map("storage_path")
  mimeType    String   @map("mime_type")
  sizeBytes   Int      @map("size_bytes")
  uploadedAt  DateTime @default(now()) @map("uploaded_at")

  override CampaignMetricOverride @relation(fields: [overrideId], references: [id], onDelete: Cascade)

  @@index([overrideId])
  @@map("campaign_metric_proofs")
}
